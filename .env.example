# JobProfit local environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project URL (from supabase.com → project settings → API)
VITE_SUPABASE_URL=

# Supabase anon/public key (NOT the service-role key)
VITE_SUPABASE_KEY=

# Supabase service-role key — used ONLY by Netlify functions (accept-quote.js).
# This key bypasses RLS. NEVER expose it in browser code or commit it to git.
# Set in: Netlify dashboard → Site settings → Environment variables
# Source: Supabase dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# VAPID keys for Web Push notifications (PWA push — "buzz when a quote is signed").
# Generate your own key pair ONCE with:
#   cd jobprofit && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey+'\nVAPID_PRIVATE_KEY='+k.privateKey)"
# Then add VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, and VAPID_SUBJECT to Netlify env vars.
# Mark all three as "secret" in Netlify (never commit real values here).
# Also add VITE_VAPID_PUBLIC_KEY set to the same value as VAPID_PUBLIC_KEY —
# Vite requires the VITE_ prefix to expose a variable to browser code.
#
# Server-side (Netlify functions — keep secret):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@jobprofit.co.uk
#
# Browser-side (Vite inlines at build time — same value as VAPID_PUBLIC_KEY):
VITE_VAPID_PUBLIC_KEY=
