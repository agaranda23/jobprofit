# JobProfit local environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project URL (from supabase.com → project settings → API)
VITE_SUPABASE_URL=

# Supabase anon/public key (NOT the service-role key)
VITE_SUPABASE_KEY=

# Supabase service-role key — used ONLY by Netlify functions (accept-quote.js).
# This key bypasses RLS. NEVER expose it in browser code or commit it to git.
# Set in: Netlify dashboard → Site settings → Environment variables
# Source: Supabase dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# VAPID keys for Web Push notifications (PWA push — "buzz when a quote is signed").
# Generate your own key pair ONCE with:
#   cd jobprofit && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey+'\nVAPID_PRIVATE_KEY='+k.privateKey)"
# Then add VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, and VAPID_SUBJECT to Netlify env vars.
# Mark all three as "secret" in Netlify (never commit real values here).
# Also add VITE_VAPID_PUBLIC_KEY set to the same value as VAPID_PUBLIC_KEY —
# Vite requires the VITE_ prefix to expose a variable to browser code.
#
# Server-side (Netlify functions — keep secret):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@jobprofit.co.uk
#
# Browser-side (Vite inlines at build time — same value as VAPID_PUBLIC_KEY):
VITE_VAPID_PUBLIC_KEY=

# Stripe Connect — needed by connect-oauth-start.js and connect-disconnect.js.
# Get this from: Stripe dashboard → Connect → Settings → Client ID (ca_...).
# Required before the trader "Connect Stripe" flow will work. Can be set against
# Stripe test mode (ca_test_...) without requiring platform approval.
# Also register the OAuth redirect URI in Stripe Connect settings:
#   https://<your-netlify-site>/.netlify/functions/connect-oauth-callback
STRIPE_CONNECT_CLIENT_ID=

# Stripe Connect webhook signing secret — used ONLY by stripe-connect-webhook.js (PR 3).
# This is a DIFFERENT secret from STRIPE_WEBHOOK_SECRET (the subscription webhook).
# Source: Stripe Dashboard → Developers → Webhooks → your Connect endpoint → Signing secret.
# The endpoint URL to register: https://<your-netlify-site>/.netlify/functions/stripe-connect-webhook
# Events to enable: checkout.session.completed, charge.refunded, account.application.deauthorized
# Set in: Netlify dashboard → Site settings → Environment variables (mark as secret).
STRIPE_CONNECT_WEBHOOK_SECRET=

# Google Analytics 4 — Measurement ID for the GA4 property (format: G-XXXXXXXXXX).
# Create a property at https://analytics.google.com → Admin → Create Property.
# Find the Measurement ID in: Admin → Data Streams → your stream → Measurement ID.
# Add to Netlify: Site settings → Environment variables → Add variable.
# Without VITE_GA4_ID the analytics block is skipped entirely (no errors in dev/preview).
#
# IMPORTANT — after adding this key, register the following as Custom Dimensions
# in the GA4 admin UI (Admin → Custom Definitions → Custom Dimensions) or they
# will not appear in funnel explorations or reports:
#   Event-scoped:  upgrade_trigger, channel, source, plan, tab
#   User-scoped:   plan, trial_ends_at
VITE_GA4_ID=

# Anthropic API key — used ONLY by Netlify functions (generate-quote.js).
# NEVER expose this in browser code or commit it to git.
# Get from: https://console.anthropic.com → API Keys.
# Set in: Netlify dashboard → Site settings → Environment variables (mark as secret).
ANTHROPIC_API_KEY=
