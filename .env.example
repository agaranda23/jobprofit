# JobProfit local environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project URL (from supabase.com → project settings → API)
VITE_SUPABASE_URL=

# Supabase anon/public key (NOT the service-role key)
VITE_SUPABASE_KEY=

# Supabase service-role key — used ONLY by Netlify functions (accept-quote.js).
# This key bypasses RLS. NEVER expose it in browser code or commit it to git.
# Set in: Netlify dashboard → Site settings → Environment variables
# Source: Supabase dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key for trader notification emails (Phase G-2 follow-up).
# Sign up at https://resend.com (free tier: 3000/mo, 100/day).
# Add this to Netlify environment variables and mark as secret.
# The accept function gracefully skips the email and returns 200 if this is unset.
RESEND_API_KEY=

# Public-facing app URL — used in the "Open JobProfit" link inside notification emails.
# Defaults to https://jobprofit.netlify.app if unset. Override in staging/local envs.
APP_BASE_URL=https://jobprofit.netlify.app
