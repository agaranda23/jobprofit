# E2E test environment variables — copy to e2e/.env.test and fill in real
# values, or export them in CI. NEVER commit e2e/.env.test.
#
# This suite runs against a REAL Supabase project (per QAE's plan — only
# Stripe is stubbed). Point it at a dedicated dev/staging Supabase project,
# NOT production, if one exists — seedTestUsers() creates real auth users.

# ── App under test ────────────────────────────────────────────────────────
# Unset for local `vite dev` (defaults to http://localhost:5173 — UI-shell
# specs only, no Netlify Functions). Set to a Netlify deploy preview or
# `netlify dev`'s URL (default http://localhost:8888) for every spec that
# touches /.netlify/functions/* or the /p/<token> redirect.
PLAYWRIGHT_TEST_URL=

# ── Supabase (same vars the app itself uses — see repo root .env.example) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
# Service-role key — bypasses RLS. Used ONLY by this suite's Node-side
# fixtures/helpers (seeding, teardown, polling) — never sent to the browser
# under test. Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe Connect webhook signing secret ───────────────────────────────────
# ⚠️ NAME CORRECTION: this must be STRIPE_CONNECT_WEBHOOK_SECRET, not
# STRIPE_WEBHOOK_SECRET (that name belongs to the separate subscription
# webhook, netlify/functions/stripe-webhook.js). Use a TEST MODE Connect
# webhook signing secret only — see stripe-connect-webhook.js's docblock for
# how to create one in the Stripe dashboard (Connect → Webhooks).
STRIPE_CONNECT_WEBHOOK_SECRET=

# ── Optional — only needed if prod-smoke.spec.js runs against a domain other
# than the hardcoded default (https://ohnar.co.uk). See that file's docblock
# re: the in-progress jobprofit.co.uk → ohnar.co.uk migration.
# (Reuses PLAYWRIGHT_TEST_URL above — no separate var needed.)
